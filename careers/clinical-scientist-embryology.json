  "title": "Clinical Scientist — Embryology",
  "sector": "Healthcare Science",
  "sub_sector": "Laboratory Sciences",
  "source_url": "https://www.careers.nhs.scot/explore-careers/healthcare-science/laboratory-sciences/clinical-scientist-embryology/",
  "published": "18/04/2023",
  "last_updated": "09/12/2025",
  "how_to_become": "To become a clinical scientist in embryology, complete a postgraduate-level work-based training programme. Alternatively, apply for registration through an equivalence route if you have significant professional experience and relevant qualifications.",
  "description": "Clinical scientists in embryology are reproductive scientists who help people with sub-fertility or infertility to have children. They carry out diagnostic tests to determine a patient's fertility level and provide information about treatment options most likely to result in a successful birth.",
  "role_overview": "As a clinical embryologist, you'll ensure patients are well-informed about fertility treatments. You'll collect eggs and sperm, carry out IVF and ICSI procedures, monitor embryos, select the strongest for transfer, and manage cryopreservation of embryos, eggs, and sperm for future use.",
  "assisted_reproductive_technologies": [
    "In vitro fertilisation (IVF) — collecting eggs and sperm and mixing them in the laboratory.",
    "Intracytoplasmic sperm injection (ICSI) — injecting a single live sperm directly into the egg when sperm quality is low.",
    "Cryopreservation — freezing embryos, eggs, or sperm for future use or fertility preservation."
  ],
  "entry_requirements": {
    "overview": "An undergraduate honours degree at SCQF level 10 in a relevant subject is required to apply for the clinical scientist training programme.",
