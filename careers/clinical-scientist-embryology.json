  "chunks": [
    { "chunk_id": "clinical-scientist-embryology-001", "section": "how_to_become", "text": "To become a clinical scientist in embryology, complete a 3-year postgraduate work-based training programme (STP or alternative). An equivalence route is available for those with significant NHS embryology experience." },
    { "chunk_id": "clinical-scientist-embryology-002", "section": "description", "text": "Clinical scientists in embryology are reproductive scientists who help people with sub-fertility or infertility to have children, carrying out diagnostic tests and providing information about treatment options most likely to result in a successful birth." },
    { "chunk_id": "clinical-scientist-embryology-003", "section": "role_overview", "text": "Clinical embryologists carry out IVF and ICSI procedures, monitor and select embryos for transfer, manage cryopreservation of embryos, eggs, and sperm, and ensure patients are well-informed about fertility treatment options." },
    { "chunk_id": "clinical-scientist-embryology-004", "section": "entry_requirements", "text": "Useful school subjects include English, Maths, Biology, and Chemistry. An undergraduate honours degree at SCQF level 10 in Biomedical Sciences, Biology, Microbiology, Genetics, or Biochemistry is required." },
    { "chunk_id": "clinical-scientist-embryology-005", "section": "education_and_training", "text": "Training is via the 3-year Scientist Training Programme (STP) or an alternative work-based training programme. On completion, registration with the HCPC as a clinical scientist is required. An equivalence route is available for experienced practitioners." },
    { "chunk_id": "clinical-scientist-embryology-006", "section": "learning_and_development", "text": "Clinical embryologists must maintain CPD and HCPC registration. Further qualifications such as PhDs and professional doctorates support progression to senior and specialist roles." },
    { "chunk_id": "clinical-scientist-embryology-007", "section": "professional_bodies", "text": "Clinical scientists in embryology must register with the HCPC. They can also join the Academy for Healthcare Science (AHCS), Association of Clinical Scientists (ACS), and Association of Reproductive and Clinical Scientists (ARCS)." }
  ]
}